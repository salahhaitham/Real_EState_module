<odoo>
     <record id="property_history_tree_view" model="ir.ui.view">
         <field name="name">property </field>
         <field name="model">property.history</field>
         <field name="arch" type="xml">
              <list class="tree_style" >
                  <field name="property_id"/>
                   <field name="user_id"/>
                  <field name="old_state"/>
                  <field name="new_state"/>

              </list>
         </field>

     </record>



<record id="property_history_form" model="ir.ui.view">
    <field name="name">property </field>
    <field name="model">property.history</field>
    <field name="arch" type="xml">
        <form >
            <sheet>

                <group>
                    <group >
                        <field name="old_state"/>
                        <field name="user_id"/>

                    </group>
                    <group >
                        <field name="old_state"/>
                        <field name="new_state"/>


                    </group>
                </group>


            </sheet>

        </form>
    </field>
</record>




    <record id="properties_history_action" model="ir.actions.act_window">
        <field name="name">property </field>
        <field name="res_model">property.history</field>
    </record>
<menuitem id="properties_history_view_id" name="property_history" parent="property_menu" action="properties_history_action"/>
</odoo>

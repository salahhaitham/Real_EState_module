<odoo>
<record id="property_History_tree_view" model="ir.ui.view">
         <field name="name">property </field>
         <field name="model">property.history</field>
         <field name="arch" type="xml">
              <list class="tree_style" >

                  <field name="user_id"/>
                  <field name="property_id"/>
                   <field name="old_state"/>
                  <field name="new_state"/>

              </list>
         </field>

     </record>



<record id="property_history_form" model="ir.ui.view">
    <field name="name">property </field>
    <field name="model">property.history</field>
    <field name="arch" type="xml">
        <form >
            <sheet>

                <group>
                    <group >
                        <field name="user_id" readonly="1"/>
                        <field name="property_id"  readonly="1"/>

                    </group>
                    <group >
                        <field name="old_state"  readonly="1"/>
                        <field name="new_state" readonly="1" />

                    </group>
                </group>
      <notebook>
                 <page string="bedrooms">
                     <field name="property_Lines_ids" >

                         <list >
                             <field name="description" readonly="1"></field>
                               <field name="area" readonly="1"></field>
                         </list>
                     </field>
                 </page>
             </notebook>

            </sheet>

        </form>
    </field>
</record>
 <record id="history_action" model="ir.actions.act_window">
        <field name="name">history</field>
        <field name="res_model">property.history</field>
            <field name="view_mode">list,form</field>
    </record>
 <menuitem id="property_history_view_id" name="history" parent="property_menu" action="history_action"/>

</odoo>

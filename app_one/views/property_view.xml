<odoo>
     <record id="property_tree_view" model="ir.ui.view">
         <field name="name">property </field>
         <field name="model">property</field>
         <field name="arch" type="xml">
              <list class="tree_style" decoration-danger="is_late">
                  <field name="name"/>
                   <field name="description"/>

                  <field name="is_late" column_invisible="True"/>
                  <field name="owner_id"/>
                  <field name="state"/>
                   <field name="date_available"/>
                  <field name="garage"/>
                  <field name="garden"/>
                  <field name="post_code"/>
                  <field name="livig_area"/>
                  <field name="expected_price"/>
                  <field name="selleing_price"/>
                  <field name="faceds"/>
                  <field name="garden_orientation"/>
                  <field name="bathrooms" optional="1"/>

              </list>
         </field>

     </record>

  <record id="property_search_view" model="ir.ui.view">
         <field name="name">property search</field>
         <field name="model">property</field>
         <field name="arch" type="xml">
              <search>

                  <field name="name"/>
                  <field name="post_code"/>

                  <filter name="with_garden" string="With Garden" domain="[('garden','=',True)]"/>
                   <filter name="without_garden" string="Without Garden" domain="[('garden','=',False)]"/>
                  <filter name="with_garage" string="With garage" domain="[('garage','=',True)]"/>
                    <filter name="garage" string="garage" context="{'group_by':'garage'}"/>
              </search>
         </field>

     </record>

<record id="property_form" model="ir.ui.view">
    <field name="name">property </field>
    <field name="model">property</field>
    <field name="arch" type="xml">
        <form >
      <header >

                    <button name="draft_button" string="Draft" type="object" class="btn_primary" invisible="state in ('draft','closed')"/>
                    <button name="pending_button" string="Pending" type="object" class="btn_secondary" invisible="state != 'draft'"/>
                    <button name="sold_button" string="Sold" type="object" class="btn_success" invisible="state != 'pending'"/>
                    <button name="action_btn" string="Action" type="object" class="btn_success" />
                     <field name="state" widget="statusbar" statusbar_visible="draft,pending,sold,closed"/>
                </header>
            <sheet>


              <div name="button_box" class="oe_button_box">
                  <button name="open_owner_id" string="Owner" invisible="not owner_id" type="object" icon="fa-user"/>
              </div>
                <widget name="web_ribbon"
                        title="Archived"
                         bg_color="bg-danger"
                         invisible="active"/>
                 <widget name="web_ribbon"
                        title="Sold"
                         bg_color="bg-success"
                         invisible="state != 'sold'"/>


               <div class="oe_title">
                    <label for="ref"/>
    <h1>
        <field name="ref"/>
    </h1>
    <label for="name"/>
    <h3>
        <field name="name" readonly="state=='closed'"/>
    </h3>
</div>
                <group>
                    <group string="general_info">
                        <field name="faceds" readonly="state=='closed'"/>
                        <field name="owner_id" readonly="state=='closed'"/>
                        <field name="owner_phone" readonly="state=='closed'"/>
                        <field name="owner_address" readonly="state=='closed'"/>
                        <field name="livig_area" readonly="state=='closed'"/>
                        <field name="date_available" readonly="state=='closed'"/>
                        <field name="garage" readonly="state=='closed'"/>
                         <field name="selleing_price" readonly="state=='closed'"/>
                           <field name="expected_price" readonly="state=='closed'"/>
                        <field name="diff"/>
                    </group>
                    <group string="specific_info">
                        <field name="post_code" readonly="state=='closed'"/>
                        <field name="garden" readonly="state=='closed'"/>
                        <field name="garden_orientation" readonly="state=='closed'"/>
                        <field name="bathrooms" readonly="state=='closed'"/>
                        <field name="tag_ids" widget="many2many_tags" readonly="state=='closed'"/>
                       <field name="expected_selling_date" readonly="state=='closed'"/>
                        <field name="is_late" invisible="1" readonly="state=='closed'"/>

                    </group>
                </group>
                <group>
                            <field name="description"/>
                </group>
             <notebook>
                 <page string="bedrooms">
                     <field name="property_lines_id" >

                         <list editable="bottom">
                             <field name="description"></field>
                               <field name="area"></field>
                         </list>
                     </field>
                 </page>
             </notebook>
            </sheet>
            <chatter/>
        </form>
    </field>
</record>


    <record id="automated_action_id" model="ir.cron">
        <field name="name">check property Date</field>
        <field name="model_id" ref="model_property"> </field>
        <field name="state" >code</field>
        <field name="code" >model.check_expected_sellingDate() </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>

        <field name="active">True</field>
    </record>



   <record id="change_state_wizard_id" model="ir.actions.server">
       <field name="name">change Close state</field>
       <field name="model_id" ref="model_property"></field>
       <field name="binding_model_id" ref="model_property"></field>
       <field name="state">code</field>
       <field name="code">
           action= records.change_state_wizard()
       </field>



   </record>






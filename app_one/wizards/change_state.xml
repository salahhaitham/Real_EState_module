<odoo>

<record id="change_state_form" model="ir.ui.view">
    <field name="name">change_state form</field>
    <field name="model">change.state</field>
    <field name="arch" type="xml">
        <form >
            <sheet>

                <group>

                        <field name="state" required="1"/>

                        <field name="reason" required="1"/>

                </group>
                  <footer>
                      <button string="cancel" special="cancel"></button>
                        <button name="confirm_button" string="Confirm" type="object"></button>
                  </footer>

            </sheet>
        </form>
    </field>
</record>

    <record id="change_state_wizard_action" model="ir.actions.act_window">
        <field name="name">chage_state wizard </field>
        <field name="res_model">change.state</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>

    </record>

</odoo>